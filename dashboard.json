        },
        "tooltip": {
          "mode": "single",
          "sort": "none"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "apache_ddos_traffic_total",
          "legendFormat": "Total 429 responses",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${DS_PROMETHEUS}"
          },
          "editorMode": "code",
          "expr": "increase(apache_ddos_traffic_total[1m])",
          "legendFormat": "429 responses in last 1m",
          "range": true,
          "refId": "B"
        }
      ],
      "title": "DDoS Traffic - Apache HTTP 429 Rate Limit Events",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
