          "range": true,
          "refId": "A"
        }
      ],
      "title": "Security Alerts - HTTP 401/403",
      "type": "stat"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
